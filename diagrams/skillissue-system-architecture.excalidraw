      "index": "a32",
      "roundness": null,
      "isDeleted": false,
      "seed": 1948273650,
      "version": 1,
      "versionNonce": 482910375,
      "updated": 1749000000000,
      "link": null,
      "locked": false,
      "text": "Step 1: Discover\n\nCode Search API\n6 size partitions\n10 pages each\nup to 6000 results",
      "originalText": "Step 1: Discover\n\nCode Search API\n6 size partitions\n10 pages each\nup to 6000 results",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "box-step1",
      "lineHeight": 1.25,
      "autoResize": true,
      "boundElements": []
    },
    {
      "id": "text-step2",
      "type": "text",
      "x": 495,
      "y": 400,
      "width": 210,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a33",
      "roundness": null,
      "isDeleted": false,
      "seed": 5738920146,
      "version": 1,
      "versionNonce": 293847015,
      "updated": 1749000000000,
      "link": null,
      "locked": false,
      "text": "Step 2: Filter\n\nGraphQL batch (50/call)\nFilter repos ≥ 10 ⭐\nGet metadata: stars,\nlanguage, topics, avatar",
      "originalText": "Step 2: Filter\n\nGraphQL batch (50/call)\nFilter repos ≥ 10 ⭐\nGet metadata: stars,\nlanguage, topics, avatar",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "box-step2",
      "lineHeight": 1.25,
      "autoResize": true,
      "boundElements": []
    },
    {
      "id": "text-step3",
      "type": "text",
      "x": 875,
      "y": 400,
      "width": 210,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
