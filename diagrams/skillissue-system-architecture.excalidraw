      "updated": 1749000000000,
      "link": null,
      "locked": false,
      "text": "GitHub\nRepos with SKILL.md files (Anthropic, Vercel, OpenAI, HuggingFace,\nOpenClaw + 500+ community repos)",
      "originalText": "GitHub\nRepos with SKILL.md files (Anthropic, Vercel, OpenAI, HuggingFace,\nOpenClaw + 500+ community repos)",
