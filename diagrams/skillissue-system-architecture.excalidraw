      "seed": 3847291056,
      "version": 1,
      "versionNonce": 482910375,
      "updated": 1749000000000,
      "link": null,
      "locked": false,
      "text": "Step 3: Deep Scan\n\nTrees API (recursive)\nFind ALL SKILL.md per repo\nCap: 500 skills/repo\nSkip: openclaw/skills",
      "originalText": "Step 3: Deep Scan\n\nTrees API (recursive)\nFind ALL SKILL.md per repo\nCap: 500 skills/repo\nSkip: openclaw/skills",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
